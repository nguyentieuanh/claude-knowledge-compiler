{
  "name": "developer-knowledge-compiler",
  "version": "1.0.0",
  "description": "Compile developer knowledge across coding sessions — Claude Code plugin",
  "author": "DKC",
  "license": "MIT",
  "type": "module",
  "bin": {
    "dkc": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    ".claude-plugin",
    "commands",
    "skills",
    "agents",
    "hooks"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "build:release": "tsup --config tsup.release.ts",
    "release": "npm run build:release && bash scripts/package-release.sh",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "dotenv": "^17.4.1",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "openai": "^6.33.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
